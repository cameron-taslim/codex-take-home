generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ExperimentStatus {
  draft
  generating
  generated
  generation_failed
}

enum GenerationRunStatus {
  pending
  running
  succeeded
  failed
}

model User {
  id           String       @id @default(cuid())
  email        String       @unique
  displayName  String?
  passwordHash String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  experiments  Experiment[]
}

model Experiment {
  id                    String               @id @default(cuid())
  userId                String
  name                  String
  pageType              String
  targetAudience        String
  tone                  String
  brandConstraints      String
  seedContext           String?
  whatToTest            String               @default("")
  approvedBrief         Json?
  status                ExperimentStatus     @default(draft)
  latestGenerationRunId String?              @unique
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  user                  User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  generationRuns        CodexGenerationRun[]
  variants              ExperimentVariant[]
  latestGenerationRun   CodexGenerationRun?  @relation("LatestGenerationRun", fields: [latestGenerationRunId], references: [id])

  @@index([userId, updatedAt])
}

model CodexGenerationRun {
  id             String              @id @default(cuid())
  experimentId   String
  status         GenerationRunStatus
  promptSnapshot Json
  startedAt      DateTime
  completedAt    DateTime?
  errorMessage   String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  experiment     Experiment          @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  latestFor      Experiment?         @relation("LatestGenerationRun")
  variants       ExperimentVariant[]

  @@index([experimentId, createdAt])
}

model ExperimentVariant {
  id              String             @id @default(cuid())
  generationRunId String
  experimentId    String
  label           String
  headline        String
  subheadline     String?
  bodyCopy        String
  ctaText         String
  layoutNotes     String
  previewConfig   Json
  position        Int
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  generationRun   CodexGenerationRun @relation(fields: [generationRunId], references: [id], onDelete: Cascade)
  experiment      Experiment         @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@index([experimentId, position])
  @@index([generationRunId, position])
}
